# POSTGRES_URL: Required for database connection.
# Set this in Vercel Dashboard -> Settings -> Environment Variables
# Or locally in .env file for development
# Get this from your Neon/Vercel Postgres dashboard
POSTGRES_URL="postgresql://user:password@host/database?sslmode=require"

# Alternative: DATABASE_URL (same format, fallback if POSTGRES_URL not set)
# DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# GEMINI_API_KEY: Required for Gemini AI API calls (optional).
GEMINI_API_KEY="MY_GEMINI_API_KEY"
